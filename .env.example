# Wintermute environment configuration
# Copy this file to .env and fill in the real values.
# .env is git-ignored and loaded automatically at startup via python-dotenv.

# ── Gemini API ────────────────────────────────────────────────────────────────
# API key for Google Gemini (AI Studio).
# Required unless GOOGLE_GENAI_USE_VERTEXAI=True.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Workspace ─────────────────────────────────────────────────────────────────
# Absolute path to the root of your local Freeside workspace.
# This must point to the directory that contains the packages/ sub-directory.
# Example: /home/yourname/Code/freeside
WINTERMUTE_WORKSPACE_ROOT=/path/to/your/freeside/workspace
